#!/bin/bash
#
# KubeXM ISO Installation Script
# This script runs on the live ISO environment and installs the Kubernetes cluster
#

set -e

KUBEXM_VERSION="{{ .KubexmVersion }}"
CLUSTER_NAME="{{ .ClusterName }}"
PACKAGES_DIR="/kubexm/packages"
CONFIG_FILE="/kubexm/config/{{ .ConfigFileName }}"
LOG_FILE="/var/log/kubexm-install.log"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

log() {
    echo -e "${GREEN}[KubeXM]${NC} $1" | tee -a "$LOG_FILE"
}

warn() {
    echo -e "${YELLOW}[KubeXM WARNING]${NC} $1" | tee -a "$LOG_FILE"
}

error() {
    echo -e "${RED}[KubeXM ERROR]${NC} $1" | tee -a "$LOG_FILE"
    exit 1
}

check_requirements() {
    log "Checking system requirements..."

    # Check if running as root
    if [ "$EUID" -ne 0 ]; then
        error "This script must be run as root"
    fi

    # Check available disk space (minimum 50GB for a full K8s installation)
    available_space=$(df -BG / | awk 'NR==2 {print $4}' | sed 's/G//')
    if [ "$available_space" -lt 50 ]; then
        warn "Less than 50GB of disk space available. Installation may fail."
    fi

    # Check memory (minimum 2GB)
    total_mem=$(free -m | awk 'NR==2 {print $2}')
    if [ "$total_mem" -lt 2048 ]; then
        warn "Less than 2GB of memory available. Kubernetes may not function properly."
    fi

    # Check CPU cores
    cpu_cores=$(nproc)
    if [ "$cpu_cores" -lt 2 ]; then
        warn "Less than 2 CPU cores detected. Performance may be affected."
    fi

    log "Requirements check complete. CPUs: $cpu_cores, Memory: ${total_mem}MB, Disk: ${available_space}GB free"
}

detect_os() {
    log "Detecting operating system..."

    if [ -f /etc/os-release ]; then
        . /etc/os-release
        OS_NAME="$NAME"
        OS_VERSION="$VERSION_ID"
    else
        OS_NAME="Unknown"
        OS_VERSION="Unknown"
    fi

    log "Detected OS: $OS_NAME $OS_VERSION"
}

configure_network() {
    log "Configuring network..."

    # Enable IP forwarding
    echo 1 > /proc/sys/net/ipv4/ip_forward

    # Configure nameserver if not set
    if [ ! -s /etc/resolv.conf ]; then
        echo "nameserver 8.8.8.8" > /etc/resolv.conf
    fi

    log "Network configuration complete"
}

partition_disk() {
    log "Starting disk partitioning..."

    local disk="${1:-/dev/sda}"

    if [ ! -b "$disk" ]; then
        error "Disk $disk does not exist"
    fi

    warn "All data on $disk will be ERASED!"
    read -p "Continue? (yes/no): " confirm
    if [ "$confirm" != "yes" ]; then
        error "Installation cancelled by user"
    fi

    # Unmount any mounted partitions
    umount -lf ${disk}* 2>/dev/null || true

    # Create new partition table
    parted -s "$disk" mklabel gpt

    # Create boot partition (1GB)
    parted -s "$disk" mkpart primary ext4 1MiB 1024MiB
    parted -s "$disk" set 1 boot on

    # Create root partition (rest of disk)
    parted -s "$disk" mkpart primary ext4 1024MiB 100%

    # Format partitions
    mkfs.ext4 -F ${disk}1
    mkfs.ext4 -F ${disk}2

    # Mount partitions
    mkdir -p /target
    mount ${disk}2 /target
    mkdir -p /target/boot
    mount ${disk}1 /target/boot

    log "Disk partitioning complete"
}

install_base_system() {
    log "Installing base system..."

    # Extract base filesystem from ISO
    log "Extracting base filesystem (this may take several minutes)..."

    local squashfs="/cdrom/casper/filesystem.squashfs"
    if [ -f "$squashfs" ]; then
        unsquashfs -d /target/squashfs-root "$squashfs"
        rsync -aHAX --exclude='/proc/*' --exclude='/sys/*' --exclude='/dev/*' --exclude='/run/*' --exclude='/tmp/*' --exclude='/var/log/*' /target/squashfs-root/ /target/
        rm -rf /target/squashfs-root
    else
        warn "Squashfs not found. Skipping base system extraction."
    fi

    log "Base system installation complete"
}

install_kubexm_packages() {
    log "Installing KubeXM packages..."

    if [ ! -d "$PACKAGES_DIR" ]; then
        error "Packages directory not found: $PACKAGES_DIR"
    fi

    # Create kubexm directories
    mkdir -p /target/opt/kubexm/{bin,config,packages,logs}
    mkdir -p /target/etc/kubernetes
    mkdir -p /target/etc/cni/net.d
    mkdir -p /target/etc/containerd
    mkdir -p /target/var/lib/kubelet
    mkdir -p /target/var/lib/etcd
    mkdir -p /target/var/log/kubernetes

    # Copy packages
    cp -r "$PACKAGES_DIR"/* /target/opt/kubexm/packages/

    # Make binaries executable
    find /target/opt/kubexm/packages -type f -executable -exec chmod +x {} \; 2>/dev/null || true

    # Copy and configure kubexm
    cp "$CONFIG_FILE" /target/etc/kubexm/config.yaml

    # Create symlinks for kubernetes binaries
    ln -sf /opt/kubexm/packages/kubernetes/kubeadm/*/kubeadm /target/usr/local/bin/kubeadm
    ln -sf /opt/kubexm/packages/kubernetes/kubelet/*/kubelet /target/usr/local/bin/kubelet
    ln -sf /opt/kubexm/packages/kubernetes/kubectl/*/kubectl /target/usr/local/bin/kubectl

    log "KubeXM packages installed"
}

configure_system() {
    log "Configuring system..."

    # Mount essential filesystems
    mount -t proc proc /target/proc
    mount -t sysfs sys /target/sys
    mount --bind /dev /target/dev

    # Chroot and configure
    cat << 'CHROOT_EOF' | chroot /target /bin/bash
set -e

# Disable swap
swapoff -a
sed -i '/swap/d' /etc/fstab 2>/dev/null || true

# Configure kernel modules
cat > /etc/modules-load.d/kubexm.conf << 'MODULES'
overlay
br_netfilter
MODULES

# Load modules
modprobe overlay 2>/dev/null || true
modprobe br_netfilter 2>/dev/null || true

# Configure sysctl
cat > /etc/sysctl.d/99-kubexm.conf << 'SYSCTL'
net.bridge.bridge-nf-call-iptables  = 1
net.ipv4.ip_forward                 = 1
net.ipv4.conf.all.forwarding        = 1
net.ipv4.conf.default.forwarding     = 1
net.ipv4.conf.all.rp_filter          = 0
net.ipv4.conf.default.rp_filter      = 0
net.ipv6.conf.all.forwarding        = 1
net.ipv6.conf.default.forwarding     = 1
fs.inotify.max_user_watches         = 524288
fs.file-max                         = 2097152
kernel.pid_max                      = 4194304
vm.max_map_count                    = 262144
vm.swappiness                       = 0
SYSCTL

sysctl --system

# Set hostname
echo "{{ .ClusterName }}-node-01" > /etc/hostname

# Configure hosts
cat >> /etc/hosts << 'HOSTS'
127.0.1.1 {{ .ClusterName }}-node-01
HOSTS

# Install containerd
if [ -d /opt/kubexm/packages/containerd ]; then
    cp /opt/kubexm/config/containerd.toml /etc/containerd/config.toml 2>/dev/null || true
fi

# Configure containerd systemd drop-in
mkdir -p /etc/systemd/system/containerd.service.d
cat > /etc/systemd/system/containerd.service.d/10-kubexm.conf << 'CONTAINERD_DROPIN'
[Service]
ExecStartPost=/sbin/modprobe overlay
CONTAINERD_DROPIN

systemctl daemon-reload 2>/dev/null || true

echo "System configuration complete"
CHROOT_EOF

    # Unmount
    umount -lf /target/proc /target/sys /target/dev 2>/dev/null || true

    log "System configuration complete"
}

install_bootloader() {
    log "Installing bootloader..."

    local disk="${1:-/dev/sda}"

    # Install GRUB
    if command -v grub-install >/dev/null 2>&1; then
        grub-install --target=x86_64-efi --efi-directory=/target/boot --bootloader-id=KubeXM --no-nvram "$disk" 2>/dev/null || \
        grub-install --target=i386-pc "$disk" --boot-directory=/target/boot 2>/dev/null || \
        warn "GRUB installation may have failed"
    fi

    # Generate GRUB config
    if [ -f /target/boot/grub/grub.cfg ]; then
        cp /cdrom/kubexm/grub.cfg /target/boot/grub/grub.cfg 2>/dev/null || true
    fi

    log "Bootloader installation complete"
}

create_post_install_script() {
    log "Creating post-installation script..."

    cat > /target/opt/kubexm/post-install.sh << 'POSTEOF'
#!/bin/bash
#
# Post-installation script to be run after first boot
#

CLUSTER_NAME="{{ .ClusterName }}"
CONFIG_FILE="/etc/kubexm/config.yaml"
LOG_FILE="/var/log/kubexm-postinstall.log"

log() {
    echo "[KubeXM PostInstall] $1"
}

log "Starting post-installation..."

# Start containerd
systemctl enable containerd
systemctl start containerd

# Pull required pause image
ctr -n k8s.io images pull registry.k8s.io/pause:3.9 2>/dev/null || true

# Initialize kubeadm if this is a master node
if grep -q 'role.*master' /etc/kubexm/config.yaml; then
    log "Initializing Kubernetes control plane..."
    kubeadm init --config=/etc/kubexm/kubeadm-config.yaml --upload-certs 2>&1 | tee /var/log/kubexm-init.log

    # Configure kubeconfig for root
    export KUBECONFIG=/etc/kubernetes/admin.conf
    kubectl --kubeconfig=$KUBECONFIG apply -f /opt/kubexm/packages/manifests/ 2>/dev/null || true

    # Copy kubeconfig to home directory
    mkdir -p /root/.kube
    cp /etc/kubernetes/admin.conf /root/.kube/config
    chmod 600 /root/.kube/config
fi

log "Post-installation complete"
POSTEOF

    chmod +x /target/opt/kubexm/post-install.sh

    # Create systemd service for post-install
    cat > /target/etc/systemd/system/kubexm-postinstall.service << 'SVCEOF'
[Unit]
Description=KubeXM Post Installation Service
After=network.target

[Service]
Type=oneshot
ExecStart=/opt/kubexm/post-install.sh
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
SVCEOF

    ln -sf /etc/systemd/system/kubexm-postinstall.service /target/etc/systemd/system/multi-user.target.wants/kubexm-postinstall.service 2>/dev/null || true

    log "Post-installation script created"
}

main() {
    log "========================================="
    log "  KubeXM ISO Installation Started"
    log "  Version: $KUBEXM_VERSION"
    log "  Cluster: $CLUSTER_NAME"
    log "========================================="

    check_requirements
    detect_os
    configure_network

    # Get target disk from command line or prompt
    TARGET_DISK="${1:-/dev/sda}"

    partition_disk "$TARGET_DISK"
    install_base_system
    install_kubexm_packages
    configure_system
    install_bootloader "$TARGET_DISK"
    create_post_install_script

    log "========================================="
    log "  Installation Complete!"
    log "========================================="
    log "Please reboot the system. After reboot:"
    log "  1. The system will start Kubernetes cluster initialization"
    log "  2. Check logs at: /var/log/kubexm-install.log"
    log "  3. Check Kubernetes status with: kubectl get nodes"
}

# Parse command line arguments
DISK=""
while [[ $# -gt 0 ]]; do
    case $1 in
        --disk)
            DISK="$2"
            shift 2
            ;;
        --config)
            CONFIG_FILE="$2"
            shift 2
            ;;
        *)
            shift
            ;;
    esac
done

main "$DISK"
